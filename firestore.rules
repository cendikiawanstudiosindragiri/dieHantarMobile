rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the currently authenticated user has a 'driver' role.
    function isDriver() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }

    // Collection: users
    // Users can only read, create, and update their own document.
    match /users/{userId} {
      allow read, update, create: if request.auth.uid == userId;
    }

    // Collection: orders
    match /orders/{orderId} {

      // READ Access Rules
      allow read: if request.auth.uid != null && (
        // 1. Customers can read their own orders.
        resource.data.customerId == request.auth.uid ||
        // 2. Drivers can read any order that is 'PENDING'.
        (isDriver() && resource.data.status == 'PENDING') ||
        // 3. Drivers can read orders assigned to them.
        (isDriver() && resource.data.driverId == request.auth.uid)
      );

      // CREATE Access Rules
      // A logged-in user can create an order for themselves.
      allow create: if request.auth.uid != null && request.resource.data.customerId == request.auth.uid;

      // UPDATE Access Rules
      // A driver can accept a 'PENDING' order.
      allow update: if isDriver() &&
                       resource.data.status == 'PENDING' &&
                       request.resource.data.status == 'ACCEPTED' &&
                       request.resource.data.driverId == request.auth.uid;
    }
  }
}
